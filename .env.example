# Mobile-safe public configuration only
EXPO_PUBLIC_PRODUCT_NAME=Locked and Lean
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Set to `hosted` only after Supabase OAuth Server, HTTPS Site URL,
# consent path, registered clients, asymmetric signing, and server policy are configured.
EXPO_PUBLIC_OAUTH_CONSENT_MODE=

# Server-only configuration - never expose through EXPO_PUBLIC_*
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MCP_SERVER_BASE_URL=
MCP_RESOURCE_IDENTIFIER=
USDA_FDC_API_KEY=
OPEN_FOOD_FACTS_USER_AGENT=LockedAndLean/0.1 (contact@example.com)
APP_PUBLIC_URL=
OAUTH_CONSENT_URL=
