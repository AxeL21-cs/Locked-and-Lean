{
  "name": "@locked-and-lean/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "check": "npm run format && npm run typecheck && npm test && npm run build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  }
}
